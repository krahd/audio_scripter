#@p1: Rate
#@p2: Spread
#@p3: Wet
# p1 = 0.65
# p2 = 0.4
# p3 = 0.9
# Stereo barberpole AM/ring mod with continuously rising mod frequency
ramp = wrap(t * (0.05 + p1 * 0.7), 0.0, 1.0);
base = 25.0 + ramp * 1800.0;
phaseR = p2 * 3.14159;
modL = sin(6.2831853 * base * t);
modR = sin(6.2831853 * base * t + phaseR);
outL = mix(inL, inL * modL, p3);
outR = mix(inR, inR * modR, p3);

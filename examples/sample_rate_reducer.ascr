# Sample rate reducer: holds each sample for N steps, creating staircase lo-fi texture
# Distinct from bitcrusher — reduces sample rate, not bit depth
# p1 = reduction (1–32x), p2 = dry/wet
hold = 1.0 + p1 * 31.0;
state_count = state_count + 1.0;
if (gt(state_count, hold)) {
    state_count = 0.0;
    state_heldL = inL;
    state_heldR = inR;
}
outL = mix(inL, state_heldL, p2);
outR = mix(inR, state_heldR, p2);

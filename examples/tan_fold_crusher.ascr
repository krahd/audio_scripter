#@p1: Drive
#@p2: Fold
#@p3: Bit Depth
#@p4: Wet
# p1 = 0.65
# p2 = 0.5
# p3 = 0.8
# p4 = 0.5
# Tan-fold-crush cascade: three distinct nonlinearities for complex grit
# p1 = tan drive, p2 = fold threshold, p3 = bit depth, p4 = dry/wet
fn tanClip(x, drv) {
    y = tanh(x * drv * 0.7);
    return clamp(tan(y * 1.35), -1.0, 1.0);
}

drive = 0.5 + p1 * 5.5;
foldThr = 0.2 + p2 * 0.8;
steps = 2.0 + p3 * 30.0;
clippedL = tanClip(inL, drive);
clippedR = tanClip(inR, drive);
foldedL = fold(clippedL, -foldThr, foldThr);
foldedR = fold(clippedR, -foldThr, foldThr);
outL = mix(inL, crush(foldedL, steps) * 0.8, p4);
outR = mix(inR, crush(foldedR, steps) * 0.8, p4);

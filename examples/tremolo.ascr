# Tremolo: LFO modulates volume from smooth sine waves to hard square-wave chops
# p1 = rate (0.5–16 Hz), p2 = depth (0=off, 1=full cut), p3 = shape (0=sine, 1=square)
rate = 0.5 + p1 * 15.5;
sinLFO = 0.5 + 0.5 * sin(6.2831853 * rate * t);
squareLFO = pulse(rate, 0.5);
lfo = mix(sinLFO, squareLFO, p3);
gain = 1.0 - p2 + lfo * p2;
outL = inL * gain;
outR = inR * gain;

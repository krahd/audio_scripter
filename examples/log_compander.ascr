# mu-law companding: logarithmic dynamic range compression (telephony algorithm)
# p1 = mu factor (0=linear, 1=maximum compression), p2 = dry/wet
fn muEncode(x, mu) {
    s = select(gt(x, 0.0), 1.0, -1.0);
    return s * log(1.0 + mu * abs(x)) / log(1.0 + mu);
}

mu = 1.0 + p1 * 254.0;
outL = mix(inL, muEncode(inL, mu), p2);
outR = mix(inR, muEncode(inR, mu), p2);

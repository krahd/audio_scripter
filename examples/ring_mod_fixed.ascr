#@p1: Macro1
#@p2: Macro2
#@p3: Macro3
# p1 = 0.65
# p2 = 0.5
# p3 = 0.8
# Ring modulator: multiply signal by a sine carrier for metallic, bell-like tones
# p1 = carrier frequency (20–2000 Hz), p2 = stereo phase spread, p3 = dry/wet
carrier_hz = 20.0 + p1 * 1980.0;
modL = sin(6.2831853 * carrier_hz * t);
modR = sin(6.2831853 * carrier_hz * t + p2 * 3.14159);
outL = mix(inL, inL * modL, p3);
outR = mix(inR, inR * modR, p3);

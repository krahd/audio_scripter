#@p1: Macro1
#@p2: Macro2
#@p3: Macro3
# p1 = 0.65
# p2 = 0.5
# p3 = 0.8
# High-pass filter: subtracts one-pole LPF from input to isolate high frequencies
# Creates a thin, bright, no-bass sound; add resonance for a sharp peak at cutoff
# p1 = cutoff (low=heavy bass cut, high=gentle), p2 = resonance feedback, p3 = dry/wet
coeff = 0.005 + p1 * 0.3;
lpL = lpf1(inL + state_hpFbL * p2 * 0.7, coeff, 0);
lpR = lpf1(inR + state_hpFbR * p2 * 0.7, coeff, 1);
hpL = inL - lpL;
hpR = inR - lpR;
state_hpFbL = hpL;
state_hpFbR = hpR;
outL = mix(inL, hpL, p3);
outR = mix(inR, hpR, p3);

#@p1: Cutoff
#@p2: Resonance
#@p3: Wet
# p1 = 0.64
# p2 = 0.44
# p3 = 0.78
# High-pass with dedicated hp1 primitive + optional resonance color
# p1 = cutoff (low=strong bass cut), p2 = resonance color, p3 = dry/wet
coeff = 0.004 + p1 * 0.24;
res = p2 * 0.5;
hpL = hp1(inL + state_hpFbL * res, coeff, 0);
hpR = hp1(inR + state_hpFbR * res, coeff, 1);
state_hpFbL = hpL;
state_hpFbR = hpR;
outL = mix(inL, hpL, p3);
outR = mix(inR, hpR, p3);

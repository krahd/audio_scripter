#@p1: Time
#@p2: Feedback
#@p3: Width
#@p4: Wet
# p1 = 0.33
# p2 = 0.25
# p3 = 0.6
# p4 = 0.75
# Micro delay widener: short Haas delays, no feedback echo.
base = 8.0 + p1 * 520.0;
cross = p2 * 0.35;
spread = 1.08 + p3 * 0.75;

dL = delay(inL, base, 0);
dR = delay(inR, base * spread, 1);
wetL = dL * (1.0 - cross) + dR * cross;
wetR = dR * (1.0 - cross) + dL * cross;
outL = mix(inL, wetL, p4);
outR = mix(inR, wetR, p4);

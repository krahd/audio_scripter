# Additive synthesis: square wave from sum of odd Fourier harmonics via for loop
# p1 = base frequency (40–1000 Hz), p2 = harmonic count (1–16), p3 = dry/wet
freq = 40.0 + p1 * 960.0;
n = 1.0 + p2 * 15.0;
sum = 0.0;
for (k = 0; n) {
    h = 2.0 * k + 1.0;
    sum = sum + sin(6.2831853 * freq * h * t) / h;
}
sig = sum * 0.3;
outL = mix(inL, sig, p3);
outR = mix(inR, sig, p3);

#@p1: Width
#@p2: Side Drive
# p1 = 0.65
# p2 = 0.5
# Mid/Side stereo width control with optional side channel saturation
# p1 = width (0=mono, 0.5=original, 1=ultra-wide), p2 = side drive
fn encMid(l, r) {
    return (l + r) * 0.5;
}

fn encSide(l, r) {
    return (l - r) * 0.5;
}

mid = encMid(inL, inR);
side = encSide(inL, inR);
width = p1 * 2.0;
satSide = tanh(side * (1.0 + p2 * 5.0));
wSide = satSide * width;
outL = mid + wSide;
outR = mid - wSide;

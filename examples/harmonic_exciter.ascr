# Harmonic exciter: adds even harmonics via full-wave rectification of the high band
# Adds air and presence without heavy distortion
# p1 = excite amount, p2 = frequency threshold (low=all freq, high=highs only), p3 = dry/wet
hiL = inL - lpf1(inL, 0.1 + p2 * 0.35, 0);
hiR = inR - lpf1(inR, 0.1 + p2 * 0.35, 1);
exciteL = abs(hiL) * p1 * 0.6;
exciteR = abs(hiR) * p1 * 0.6;
outL = mix(inL, inL + exciteL, p3);
outR = mix(inR, inR + exciteR, p3);

#@p1: Sweep
#@p2: Resonance
#@p3: Wet
# p1 = 0.7
# p2 = 0.48
# p3 = 0.82
# Animated low-pass morph with gentle resonant feedback
lfo = 0.5 + 0.5 * sin(6.2831853 * (0.05 + p1 * 1.8) * t);
coeff = 0.002 + lfo * 0.22;
resAmt = p2 * 0.85;
inResL = inL + state_resL * resAmt;
inResR = inR + state_resR * resAmt;
fL = lpf1(inResL, coeff, 0);
fR = lpf1(inResR, coeff, 1);
state_resL = fL;
state_resR = fR;
outL = mix(inL, fL, p3);
outR = mix(inR, fR, p3);

#@p1: Drive
#@p2: Iterations
#@p3: Wet
# p1 = 0.62
# p2 = 0.55
# p3 = 0.82
# Cascaded wavefold with smoothly blended fold stages.
# p1 = pre-fold drive, p2 = fold complexity, p3 = dry/wet
drive = 1.0 + p1 * 8.0;
thr = 0.95 - p2 * 0.45;

y1L = fold(inL * drive, -thr, thr);
y1R = fold(inR * drive, -thr, thr);
y2L = fold(y1L * (1.4 + p2 * 1.2), -thr, thr);
y2R = fold(y1R * (1.4 + p2 * 1.2), -thr, thr);
y3L = fold(y2L * (1.3 + p2 * 1.5), -thr, thr);
y3R = fold(y2R * (1.3 + p2 * 1.5), -thr, thr);
y4L = fold(y3L * (1.2 + p2 * 1.8), -thr, thr);
y4R = fold(y3R * (1.2 + p2 * 1.8), -thr, thr);

stageA = smoothstep(0.10, 0.42, p2);
stageB = smoothstep(0.34, 0.72, p2);
stageC = smoothstep(0.62, 1.00, p2);
foldL = mix(mix(y1L, y2L, stageA), mix(y3L, y4L, stageC), stageB);
foldR = mix(mix(y1R, y2R, stageA), mix(y3R, y4R, stageC), stageB);
outL = mix(inL, tanh(foldL * 1.45) * 0.85, p3);
outR = mix(inR, tanh(foldR * 1.45) * 0.85, p3);
